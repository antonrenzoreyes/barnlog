# OpenAPI docs generated from canonical backend/openapi/openapi.yaml
backend/docs/swagger.json linguist-generated=true
backend/docs/swagger.yaml linguist-generated=true

# SQLC generated code
backend/internal/infrastructure/sqlite/sqlc/*.go linguist-generated=true

# oapi-codegen generated backend contract types
backend/internal/contracts/openapi/*.go linguist-generated=true

# OpenAPI generated frontend types
frontend/src/lib/api/generated/** linguist-generated=true

# Prototype artifacts (generated-ish), except canonical docs and captured state outputs
docs/prototype/** linguist-generated=true
docs/prototype/docs/** linguist-generated=false
docs/prototype/output/playwright/prototype-state/** linguist-generated=false

# Third-party skills synced into repo
.agents/skills/** linguist-generated=true

# Keep repo-owned first-party skills reviewable
.agents/skills/barnboard/** linguist-generated=false
.agents/skills/barnreview/** linguist-generated=false
