{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:oxc": "vp lint . && vp fmt --check .",
    "lint:svelte": "vp lint . && prettier --plugin prettier-plugin-svelte --check \"src/**/*.svelte\"",
    "lint": "vp run lint:oxc && vp run lint:svelte",
    "format:svelte": "prettier --plugin prettier-plugin-svelte --write \"src/**/*.svelte\"",
    "format": "vp fmt . && vp run format:svelte",
    "gen:api-types": "openapi-typescript ../backend/docs/swagger.yaml -o src/lib/api/generated/types.ts",
    "check:api-types": "vp run gen:api-types && git diff --exit-code -- src/lib/api/generated/types.ts",
    "test:unit": "vitest",
    "test": "vp run test:unit -- --run && vp run test:e2e",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@codecov/sveltekit-plugin": "^1.9.1",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.0",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plus": "0.1.11",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.2"
  },
  "packageManager": "pnpm@10.22.0"
}
