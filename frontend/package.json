{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:oxc": "oxlint . && oxfmt --check .",
    "lint:svelte": "eslint . && prettier --plugin prettier-plugin-svelte --check \"src/**/*.svelte\"",
    "lint": "bun run lint:oxc && bun run lint:svelte",
    "format:svelte": "prettier --plugin prettier-plugin-svelte --write \"src/**/*.svelte\"",
    "format": "oxfmt . && bun run format:svelte",
    "gen:api-types": "openapi-typescript ../backend/docs/swagger.yaml -o src/lib/api/generated/types.ts",
    "check:api-types": "bun run gen:api-types && git diff --exit-code -- src/lib/api/generated/types.ts",
    "test:unit": "vitest",
    "test": "bun run test:unit -- --run && bun run test:e2e",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@codecov/sveltekit-plugin": "^1.9.1",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.0.18",
    "vitest-browser-svelte": "^2.0.2"
  }
}
